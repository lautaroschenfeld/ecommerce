# Docker Compose environment (copy to `.env` in project root for VPS/prod)

# Infra
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_postgres_password
POSTGRES_DB=store_db
POSTGRES_PORT=5433
REDIS_PORT=6379

# Public service ports
FRONTEND_PORT=3000
BACKEND_PORT=9000
BACKEND_NODE_ENV=production

# URLs and CORS
STORE_CORS=https://tu-dominio.com
ADMIN_CORS=https://tu-dominio.com
AUTH_CORS=https://tu-dominio.com
STOREFRONT_URL=https://tu-dominio.com
BACKEND_PUBLIC_URL=https://tu-dominio.com/api

# Security
JWT_SECRET=replace_with_32_plus_chars_random_secret
COOKIE_SECRET=replace_with_32_plus_chars_random_secret
TRUST_PROXY_HEADERS=true

# Storefront/public config
NEXT_PUBLIC_BACKEND_URL=https://tu-dominio.com/api
BACKEND_INTERNAL_URL=http://backend:9000
NEXT_PUBLIC_PUBLISHABLE_API_KEY=pk_replace_with_real_key
NEXT_PUBLIC_STORE_LOCALE=es-AR
NEXT_PUBLIC_STORE_CURRENCY_CODE=ARS

# Optional maintenance config
CHECKOUT_IDEMPOTENCY_RETENTION_DAYS=14
CHECKOUT_IDEMPOTENCY_CLEANUP_INTERVAL_MS=900000
MAINTENANCE_JOBS_ENABLED=true
MAINTENANCE_INITIAL_DELAY_MS=45000
MAINTENANCE_TRANSFER_PROOF_INTERVAL_MS=21600000
MAINTENANCE_CHECKOUT_IDEMPOTENCY_INTERVAL_MS=900000
