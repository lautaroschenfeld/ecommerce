FROM node:20-bookworm-slim

WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1

COPY package*.json ./
RUN npm ci --include=dev

COPY . .

ARG NEXT_PUBLIC_BACKEND_URL=http://localhost:9000
ARG NEXT_PUBLIC_PUBLISHABLE_API_KEY=pk_dev_local_store_0123456789abcdef
ARG NEXT_PUBLIC_STORE_LOCALE=es-AR
ARG NEXT_PUBLIC_STORE_CURRENCY_CODE=USD
ENV NEXT_PUBLIC_BACKEND_URL=$NEXT_PUBLIC_BACKEND_URL
ENV NEXT_PUBLIC_PUBLISHABLE_API_KEY=$NEXT_PUBLIC_PUBLISHABLE_API_KEY
ENV NEXT_PUBLIC_STORE_LOCALE=$NEXT_PUBLIC_STORE_LOCALE
ENV NEXT_PUBLIC_STORE_CURRENCY_CODE=$NEXT_PUBLIC_STORE_CURRENCY_CODE

RUN npm run build

ENV NODE_ENV=production
EXPOSE 3000
CMD ["npm", "run", "start"]
