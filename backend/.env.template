STORE_CORS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001,http://192.168.0.24:3000,http://192.168.0.24:3001,http://localhost:8000
ADMIN_CORS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001,http://192.168.0.24:3000,http://192.168.0.24:3001,http://localhost:9000,http://localhost:5173
AUTH_CORS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001,http://192.168.0.24:3000,http://192.168.0.24:3001,http://localhost:9000,http://localhost:5173

# Postgres
# Nota: si usas `docker-compose.yml` de la raiz, Postgres queda expuesto en `localhost:5433`.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/store_db

# Redis (opcional, recomendado para cache de catalogo)
# Si queda vacio, el backend sigue funcionando sin cache distribuida.
REDIS_URL=redis://localhost:6379

# Auth / cookies
# Cambiar para produccion (valores largos/aleatorios).
JWT_SECRET=CHANGE_ME
COOKIE_SECRET=CHANGE_ME
# Solo habilitar si estas detras de un proxy confiable (Nginx/Cloudflare).
TRUST_PROXY_HEADERS=false
# Por seguridad, mantener en false. Solo true para pruebas locales controladas.
ALLOW_DEV_RESET_TOKEN=false

# Bootstrap admin (store account role=administrator)
# Registro publico SIEMPRE crea role=user.
# Para crear el primer Administrador usa:
# npm run bootstrap:administrator -- --email admin@tu-dominio.com --password 'StrongPass123' --token '<token>'
# Recomendado: guardar solo el hash SHA-256 del token.
CUSTOMER_BOOTSTRAP_ADMIN_TOKEN_HASH=
# Fallback (menos seguro, solo local): token en texto plano.
CUSTOMER_BOOTSTRAP_ADMIN_TOKEN=

# URLs publicas para redirects de auth/oauth
STOREFRONT_URL=http://localhost:3000
# En produccion con reverse proxy en /api, usar por ejemplo:
# BACKEND_PUBLIC_URL=https://www.tu-dominio.com/api
BACKEND_PUBLIC_URL=http://localhost:9000

# Mercado Pago Checkout Pro
# Access Token privado (APP_USR-... en produccion / TEST-... en sandbox).
MERCADOPAGO_ACCESS_TOKEN=
# Secret para validar firma de webhooks (x-signature).
# Se obtiene desde Mercado Pago al guardar la configuracion de Webhooks.
MERCADOPAGO_WEBHOOK_SECRET=
# Permite webhooks sin firma en produccion (NO recomendado).
MERCADOPAGO_ALLOW_UNSIGNED_WEBHOOKS=false
# Descriptor opcional para el resumen del comprador (max 22 chars).
MERCADOPAGO_STATEMENT_DESCRIPTOR=
# Timeout HTTP para llamadas a Mercado Pago.
MERCADOPAGO_HTTP_TIMEOUT_MS=10000
# Solo para desarrollo local sin https (ngrok/localtunnel recomendado en su lugar).
MERCADOPAGO_ALLOW_INSECURE_URLS=false

# Moneda/region de tienda (configurable por pais)
STORE_CURRENCY_CODE=usd
STORE_REGION_NAME=Region principal
STORE_REGION_COUNTRY_CODE=us

# OAuth (opcional por ahora)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_SECRET=

# Upload hardening (admin)
ADMIN_UPLOAD_MAX_FILE_SIZE_BYTES=8388608
ADMIN_UPLOAD_MAX_TOTAL_BYTES=25165824
ADMIN_UPLOAD_MAX_FILES=8
# Auto-normalizacion de imagenes de producto
# Recorta fondo (transparente/blanco/negro), agrega padding y normaliza a lienzo cuadrado.
ADMIN_UPLOAD_AUTOCROP_PADDING_PX=50
ADMIN_UPLOAD_OUTPUT_SIZE_PX=1400

# Mantenimiento automatico (cleanup comprobantes/idempotency)
MAINTENANCE_JOBS_ENABLED=true
MAINTENANCE_INITIAL_DELAY_MS=45000
MAINTENANCE_TRANSFER_PROOF_INTERVAL_MS=21600000
MAINTENANCE_CHECKOUT_IDEMPOTENCY_INTERVAL_MS=900000
